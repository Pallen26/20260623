def emd(address):
    if pd.isna(address):
        return None
    words=address.split()
    for word in reversed(words):
        if word.endswith(('동','읍','면')) or ('동' in word or '읍' in word or '면' in word):
            import re
            # '반송동105'에서 '반송동'만 쏙 뽑아내기
            match = re.search(r'.*?[동읍면]', word)
            if match:
                return match.group()
    return None
