    pk_val = int(row['총 주차면수'])
    
    key = f"{p_val}_{a_val}_{pk_val}"
    
    web_predict_dict[key] = {
        "users": int(row['predicted_users']),
        "cars": int(row['predicted_cars']),
        "rate": float(row['parking_rate'])
    }


with open('web_ml_data.json', 'w', encoding='utf-8') as f:
    json.dump(web_predict_dict, f, ensure_ascii=False, indent=4)

print(f"파일 내보내기 완료(총 {len(web_predict_dict)}개 조합)")
