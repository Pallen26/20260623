# 4-B. 엔트로피 가중 지수 (데이터 변동성 기반으로 가중치를 자동 산출)
def entropy_weights(df, cols):
    norm=(df[cols] - df[cols].min())/(df[cols].max()-df[cols].min())
    norm=norm.replace(0, 1e-9)
    p=norm /norm.sum()
    k= 1/np.log(len(df))
    entropy=-k * (p * np.log(p)).sum()
    return (1 - entropy)/(1 - entropy).sum()

